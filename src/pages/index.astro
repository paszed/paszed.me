---
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

    <title>Paszed</title>

    <style>
      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: 'Inter', -apple-system, sans-serif;
        color: #eaeaea;

        /* subtle depth */
        background: radial-gradient(
          circle at top,
          rgba(255,255,255,0.04),
          transparent 50%
        ),
        #0a0a0a;
      }

      /* GRID */
      .wrapper {
        max-width: 960px;
        margin: 0 auto;
        padding: 0 24px;
      }

      .container {
        display: grid;
        grid-template-columns: 1fr minmax(0, 640px) 1fr;
      }

      .content {
        grid-column: 2;
        padding: 140px 0;
        animation: fadeIn 0.8s ease;
      }

      @keyframes fadeIn {
        from {
          opacity: 0;
          transform: translateY(10px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      /* TYPOGRAPHY */
      h1 {
        font-size: 52px;
        letter-spacing: -1.6px;
        font-weight: 600;
        margin: 0 0 6px 0;
        line-height: 1.1;
        text-align: center;
      }

      .subtitle {
        font-size: 18px;
        color: #777;
        margin: 0 0 72px 0;
        text-align: center;
        line-height: 1.6;
      }

      h2 {
        font-size: 11px;
        letter-spacing: 1.4px;
        text-transform: uppercase;
        color: #555;
        margin-bottom: 18px;
      }

      .section {
        margin-top: 72px;
      }

      .divider {
        height: 1px;
        background: #1a1a1a;
        margin: 56px 0;
      }

      /* AVATAR */
      .avatar {
        display: block;
        margin: 0 auto 28px auto;
        width: 112px;
        height: 112px;
        border-radius: 50%;
        object-fit: cover;
        box-shadow: 0 0 0 1px #1a1a1a;
        transition: transform 0.3s ease;
      }

      .avatar:hover {
        transform: scale(1.05);
      }

      /* PROJECTS */
      .project {
        margin-bottom: 26px;
        transition: transform 0.2s ease;
      }

      .project:hover {
        transform: translateX(4px);
      }

      .project strong {
        font-size: 17px;
        font-weight: 500;
      }

      .project span {
        display: block;
        font-size: 14px;
        color: #888;
        margin-top: 4px;
        line-height: 1.6;
      }

      /* LINKS */
      .links a {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 12px;
        color: #aaa;
        text-decoration: none;
        transition: all 0.2s ease;
        font-size: 14px;
      }

      .links a:hover {
        color: #fff;
        transform: translateX(4px);
        text-shadow: 0 0 6px rgba(255,255,255,0.2);
      }

      .icon {
        width: 16px;
        height: 16px;
        fill: currentColor;
      }

      /* REVEAL */
      .reveal {
        opacity: 0;
        transform: translateY(12px);
        transition: all 0.6s ease;
      }

      .reveal.visible {
        opacity: 1;
        transform: translateY(0);
      }
    </style>
  </head>

  <body>

    <div class="wrapper">
      <div class="container">
        <div class="content">

          <!-- Avatar -->
          <img src="/profile.jpg" class="avatar" />

          <!-- Title -->
          <h1>Paszed</h1>
          <p class="subtitle">
            Building CLI tools and developer infrastructure.
          </p>

          <div class="divider"></div>

          <!-- Projects -->
          <div class="section reveal">
            <h2>Projects</h2>

            <div class="project">
              <a href="/doctor"><strong>doctor</strong></a>
              <span>Diagnose developer environments and verify installed tooling.</span>
            </div>
          </div>

          <!-- Links -->
          <div class="section reveal">
            <h2>Links</h2>

            <div class="links">

              <!-- GitHub -->
              <a href="https://github.com/paszed" target="_blank">
                <svg class="icon" viewBox="0 0 24 24">
                  <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.38 7.86 10.9.58.1.79-.25.79-.56v-2.02c-3.2.7-3.87-1.54-3.87-1.54-.52-1.33-1.28-1.68-1.28-1.68-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.2 1.77 1.2 1.03 1.76 2.7 1.25 3.36.95.1-.75.4-1.25.73-1.54-2.55-.29-5.23-1.27-5.23-5.64 0-1.25.45-2.27 1.2-3.07-.12-.3-.52-1.52.12-3.17 0 0 .98-.31 3.2 1.18.93-.26 1.93-.4 2.92-.4.99 0 2 .14 2.92.4 2.22-1.5 3.2-1.18 3.2-1.18.64 1.65.24 2.87.12 3.17.75.8 1.2 1.82 1.2 3.07 0 4.38-2.69 5.35-5.25 5.63.41.35.77 1.04.77 2.1v3.12c0 .31.21.67.8.56A10.99 10.99 0 0 0 23.5 12c0-6.35-5.15-11.5-11.5-11.5z"/>
                </svg>
                GitHub
              </a>

              <!-- Twitter -->
              <a href="https://x.com/paszed_" target="_blank">
                <svg class="icon" viewBox="0 0 24 24">
                  <path d="M18.244 2H21l-6.55 7.48L22 22h-6.828l-5.34-6.99L3.5 22H1l7.01-8.01L2 2h6.828l4.84 6.35L18.244 2z"/>
                </svg>
                Twitter
              </a>

              <!-- Email -->
              <a href="mailto:edvard@paszed.me">
                <svg class="icon" viewBox="0 0 24 24">
                  <path d="M12 13.5 2 6.75V18h20V6.75L12 13.5zm0-2.25L22 4H2l10 7.25z"/>
                </svg>
                Email
              </a>

            </div>
          </div>

        </div>
      </div>
    </div>

    <script>
      const elements = document.querySelectorAll('.reveal');

      const observer = new IntersectionObserver(entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      });

      elements.forEach(el => observer.observe(el));
    </script>

  </body>
</html>
