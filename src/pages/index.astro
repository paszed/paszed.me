<html lang="en">
<head>
<meta charset="UTF-8" />
<title>Paszed</title>

<style>
body {
margin: 0;
background: radial-gradient(
circle at top,
rgba(255, 255, 255, 0.04),
transparent 50%
),
#0a0a0a;
color: #eaeaea;
font-family: 'Inter', -apple-system, sans-serif;
}

.wrapper {
max-width: 1000px;
margin: 0 auto;
padding: 0 20px;
}

.container {
max-width: 720px;
margin: 0 auto;
padding: 120px 0;
}

/* HERO */
.hero {
text-align: center;
margin-bottom: 80px;
}

.avatar {
width: 180px; /* BIG like reference */
height: 180px;
border-radius: 50%;
object-fit: cover;
margin-bottom: 28px;
}

h1 {
font-size: 52px;
margin-bottom: 12px;
letter-spacing: -1.2px;
}

.subtitle {
color: #aaa;
font-size: 18px;
line-height: 1.6;
}

hr {
border: none;
border-top: 1px solid #222;
margin: 60px 0;
}

h2 {
font-size: 16px;
font-weight: 700;
letter-spacing: 2.5px;
text-transform: uppercase;
color: #aaa;
margin-top: 80px;
margin-bottom: 24px;
}

/* PROJECTS (FIXED CLICKABLE) */
.project {
display: block;
margin-bottom: 24px;
text-decoration: none;
}

.project-title {
font-weight: 700;
font-size: 22px;
color: #eaeaea;
letter-spacing: -0.3px;
}

.project-desc {
color: #aaa;
font-size: 16px;
line-height: 1.6;
}

.project:hover .project-title {
color: #fff;
}

/* LIST */
ul {
padding-left: 18px;
color: #aaa;
line-height: 1.7;
font-size: 16px;
}

li {
margin-bottom: 8px;
}

/* LINKS */
.links {
list-style: none;
padding-left: 0;
}

.links li {
display: flex;
align-items: center;
gap: 12px;
margin-bottom: 12px;
}

a {
color: #aaa;
text-decoration: none;
transition: 0.2s;
font-size: 16px;
}

a:hover {
color: #fff;
}

.icon {
width: 18px;
height: 18px;
fill: currentColor;
flex-shrink: 0;
}

@media (max-width: 600px) {
.container {
padding: 100px 0;
}

h1 {
font-size: 38px;
}

.avatar {
width: 140px;
height: 140px;
}
}
</style>
</head>

