---
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <link rel="icon" type="image/png" href="/favicon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

    <title>Paszed</title>

    <style>
      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: 'Inter', -apple-system, sans-serif;
        color: #eaeaea;
        background: radial-gradient(
          circle at top,
          rgba(255,255,255,0.04),
          transparent 50%
        ),
        #0a0a0a;
      }

      /* LAYOUT */
      .wrapper {
        max-width: 960px;
        margin: 0 auto;
        padding: 0 24px;
      }

      .container {
        display: grid;
        grid-template-columns: 1fr minmax(0, 640px) 1fr;
      }

      .content {
        grid-column: 2;
        padding: 140px 0;
        animation: fadeIn 0.8s ease;
      }

      @keyframes fadeIn {
        from {
          opacity: 0;
          transform: translateY(10px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      /* TYPOGRAPHY */
      h1 {
        font-size: 52px;
        letter-spacing: -1.6px;
        font-weight: 600;
        margin: 0 0 6px 0;
        line-height: 1.1;
        text-align: center;
      }

      .subtitle {
        font-size: 18px;
        color: #777;
        margin: 0 0 72px 0;
        text-align: center;
        line-height: 1.6;
      }

      h2 {
        font-size: 11px;
        letter-spacing: 1.4px;
        text-transform: uppercase;
        color: #555;
        margin-bottom: 18px;
      }

      .section {
        margin-top: 72px;
      }

      .divider {
        height: 1px;
        background: #1a1a1a;
        margin: 56px 0;
      }

      /* AVATAR */
      .avatar {
        display: block;
        margin: 0 auto 28px auto;
        width: 112px;
        height: 112px;
        border-radius: 50%;
        object-fit: cover;
        box-shadow: 0 0 0 1px #1a1a1a;
        transition: transform 0.3s ease;
      }

      .avatar:hover {
        transform: scale(1.05);
      }

      /* PROJECTS */
      .project {
        margin-bottom: 26px;
        transition: transform 0.2s ease;
      }

      .project a {
        color: #eaeaea;
        text-decoration: none;
      }

      .project:hover {
        transform: translateX(4px);
      }

      .project strong {
        font-size: 17px;
        font-weight: 500;
      }

      .project span {
        display: block;
        font-size: 14px;
        color: #888;
        margin-top: 4px;
        line-height: 1.6;
      }

      /* LINKS */
      .links a {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 14px;
        color: #aaa;
        text-decoration: none;
        transition: all 0.2s ease;
        font-size: 14px;
        padding: 6px 0;
      }

      .links a:hover {
        color: #fff;
        transform: translateX(4px);
        text-shadow: 0 0 6px rgba(255,255,255,0.2);
      }

      .icon {
        width: 16px;
        height: 16px;
        fill: currentColor;
      }

      /* REVEAL */
      .reveal {
        opacity: 0;
        transform: translateY(12px);
        transition: all 0.6s ease;
      }

      .reveal.visible {
        opacity: 1;
        transform: translateY(0);
      }

      /* 🔥 MOBILE PERFECT */
      @media (max-width: 600px) {

        .container {
          display: block;
        }

        .content {
          padding: 100px 0 80px 0;
        }

        h1 {
          font-size: 38px;
        }

        .subtitle {
          font-size: 16px;
          margin-bottom: 56px;
        }

        .section {
          margin-top: 56px;
          text-align: center;
        }

        h2 {
          text-align: center;
        }

        .divider {
          margin: 40px 0;
        }

        .project {
          text-align: center;
        }

        .project strong {
          font-size: 18px;
        }

        .project span {
          font-size: 15px;
        }

        .links {
          display: flex;
          flex-direction: column;
          align-items: center;
        }

        .links a {
          justify-content: center;
          font-size: 15px;
          padding: 8px 0;
        }

        .avatar {
          width: 96px;
          height: 96px;
          margin-bottom: 24px;
        }
      }

    </style>
  </head>

  <body>

    <div class="wrapper">
      <div class="container">
        <div class="content">

          <img src="/profile.jpg" class="avatar" />

          <h1>Paszed</h1>
          <p class="subtitle">
            Building CLI tools and developer infrastructure.
          </p>

          <div class="divider"></div>

          <div class="section reveal">
            <h2>Projects</h2>

            <div class="project">
              <a href="/doctor"><strong>doctor</strong></a>
              <span>Diagnose developer environments and verify installed tooling.</span>
            </div>
          </div>

          <div class="section reveal">
            <h2>Links</h2>

            <div class="links">

              <a href="https://github.com/paszed" target="_blank">
                GitHub
              </a>

              <a href="https://x.com/paszed_" target="_blank">
                Twitter
              </a>

              <a href="mailto:edvard@paszed.me">
                Email
              </a>

            </div>
          </div>

        </div>
      </div>
    </div>

    <script>
      const elements = document.querySelectorAll('.reveal');

      const observer = new IntersectionObserver(entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      });

      elements.forEach(el => observer.observe(el));
    </script>

  </body>
</html>
