<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>simon</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

  <style>
    html { scroll-behavior: smooth; }

    body {
      margin: 0;
      background: radial-gradient(circle at top, rgba(255,255,255,0.05), transparent 55%), #0a0a0a;
      color: #eaeaea;
      font-family: 'Inter', -apple-system, sans-serif;
    }

    .wrapper {
      max-width: 1000px;
      margin: 0 auto;
      padding: 0 20px;
    }

    .container {
      max-width: 680px;
      margin: 0 auto;
      padding: 120px 0;
      animation: fadeIn 0.6s ease;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(12px); }
      to { opacity: 1; transform: translateY(0); }
    }

    a {
      color: #aaa;
      text-decoration: none;
      transition: 0.2s;
    }

    a:hover {
      color: #fff;
      transform: translateX(3px);
    }

    .back {
      display: inline-block;
      margin-bottom: 40px;
      color: #666;
    }

    h1 {
      font-size: 56px;
      margin-bottom: 14px;
      letter-spacing: -1.4px;
    }

    .subtitle {
      color: #888;
      font-size: 19px;
      margin-bottom: 36px;
      line-height: 1.6;
    }

    .github {
      margin-bottom: 52px;
    }

    .github-link {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      color: #aaa;
    }

    .github-link:hover {
      color: #fff;
    }

    .icon {
      width: 18px;
      height: 18px;
      fill: currentColor;
    }

    h2 {
      font-size: 16px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 2.5px;
      color: #aaa;
      margin-top: 90px;
      margin-bottom: 26px;
    }

    ul {
      padding-left: 18px;
      color: #aaa;
      line-height: 1.7;
      font-size: 16px;
    }

    li {
      margin-bottom: 8px;
    }

    pre {
      background: #111;
      padding: 18px;
      border-radius: 6px;
      overflow-x: auto;
      font-size: 14px;
      line-height: 1.5;
    }

    .divider {
      height: 1px;
      background: #1a1a1a;
      margin: 52px 0;
    }

    .highlight {
      color: #fff;
    }

    @media (max-width: 600px) {
      .container { padding: 100px 0; }
      h1 { font-size: 40px; }
      .subtitle { font-size: 16px; }
    }
  </style>
</head>

<body>
  <div class="wrapper">
    <div class="container">

      <!-- Back -->
      <a href="/" class="back">← back</a>

      <!-- Title -->
      <h1>🧠 simon</h1>
      <p class="subtitle">
        System operator for developer workflows.<br/>
        <span class="highlight">Listens → reasons → acts.</span>
      </p>

      <!-- GitHub -->
      <p class="github">
        <a href="https://github.com/paszed/simon" target="_blank" class="github-link">
          <svg class="icon" viewBox="0 0 24 24">
            <path d="M12 .5C5.73.5.98 5.24.98 11.52c0 4.85 3.14 8.96 7.49 10.42.55.1.75-.24.75-.53v-1.86c-3.05.66-3.7-1.47-3.7-1.47-.5-1.26-1.22-1.6-1.22-1.6-1-.69.08-.67.08-.67 1.1.08 1.68 1.13 1.68 1.13.98 1.68 2.57 1.2 3.2.92.1-.71.38-1.2.7-1.48-2.43-.28-4.98-1.22-4.98-5.44 0-1.2.43-2.18 1.13-2.95-.11-.28-.49-1.42.11-2.96 0 0 .92-.3 3.02 1.13.88-.24 1.82-.36 2.75-.36.93 0 1.87.12 2.75.36 2.1-1.43 3.02-1.13 3.02-1.13.6 1.54.22 2.68.11 2.96.7.77 1.13 1.75 1.13 2.95 0 4.23-2.55 5.15-4.99 5.43.39.34.73 1 .73 2.02v3c0 .29.2.64.76.53 4.34-1.46 7.48-5.57 7.48-10.42C23.02 5.24 18.27.5 12 .5z"/>
          </svg>
          <span>View source on GitHub →</span>
        </a>
      </p>

      <div class="divider"></div>

      <!-- Features -->
      <h2>⚡ Capabilities</h2>
      <ul>
        <li>Interprets developer intent from input</li>
        <li>Coordinates tools across your workflow</li>
        <li>Turns raw data into actionable steps</li>
        <li>Designed for automation-first systems</li>
      </ul>

      <!-- Workflow -->
      <h2>🔁 Flow</h2>
      <pre>
input → understand → plan → execute
      </pre>

      <!-- Usage -->
      <h2>🧪 Usage</h2>
      <pre>
# example (conceptual)
simon run "check env and extract data"
simon plan workflow.json
simon execute
      </pre>

      <!-- Philosophy -->
      <h2>🧠 Philosophy</h2>
      <p class="subtitle">
        Tools shouldn’t require constant supervision.<br/>
        simon acts as the operator that connects everything together.

      </p>

    </div>
  </div>
</body>
</html>
