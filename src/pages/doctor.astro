---
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>doctor</title>

    <style>
      body {
        margin: 0;
        background: radial-gradient(
          circle at top,
          rgba(255,255,255,0.04),
          transparent 50%
        ),
        #0a0a0a;
        color: #eaeaea;
        font-family: 'Inter', -apple-system, sans-serif;
      }

      .wrapper {
        max-width: 960px;
        margin: 0 auto;
        padding: 0 24px;
      }

      .container {
        max-width: 640px;
        margin: 0 auto;
        padding: 120px 0;
      }

      a {
        color: #aaa;
        text-decoration: none;
      }

      a:hover {
        color: #fff;
      }

      .back {
        display: inline-block;
        margin-bottom: 40px;
        color: #666;
      }

      h1 {
        font-size: 42px;
        margin-bottom: 8px;
        letter-spacing: -1px;
      }

      .subtitle {
        color: #777;
        margin-bottom: 12px;
        line-height: 1.6;
      }

      /* 🔥 GitHub link */
      .github {
        margin-bottom: 40px;
      }

      .github-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #aaa;
        text-decoration: none;
        transition: all 0.2s ease;
      }

      .github-link:hover {
        color: #fff;
        transform: translateX(2px);
      }

      .icon {
        width: 16px;
        height: 16px;
        fill: currentColor;
      }

      .arrow {
        opacity: 0.6;
      }

      h2 {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 1.4px;
        color: #555;
        margin-top: 60px;
        margin-bottom: 16px;
      }

      ul {
        padding-left: 18px;
        color: #aaa;
        line-height: 1.6;
      }

      li {
        margin-bottom: 8px;
      }

      pre {
        background: #111;
        padding: 16px;
        border-radius: 6px;
        overflow-x: auto;
        font-size: 13px;
        line-height: 1.5;
      }
    </style>
  </head>

  <body>
    <div class="wrapper">
      <div class="container">

        <!-- Back -->
        <a href="/" class="back">← back</a>

        <!-- Title -->
        <h1>doctor</h1>
        <p class="subtitle">
          Developer environment diagnostics CLI.<br/>
          Automatically check, diagnose, and fix your development setup.
        </p>

        <!-- GitHub -->
        <p class="github">
          <a href="https://github.com/paszed/doctor" target="_blank" class="github-link">

            <svg class="icon" viewBox="0 0 24 24">
              <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.38 7.86 10.9.58.1.79-.25.79-.56v-2.02c-3.2.7-3.87-1.54-3.87-1.54-.52-1.33-1.28-1.68-1.28-1.68-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.2 1.77 1.2 1.03 1.76 2.7 1.25 3.36.95.1-.75.4-1.25.73-1.54-2.55-.29-5.23-1.27-5.23-5.64 0-1.25.45-2.27 1.2-3.07-.12-.3-.52-1.52.12-3.17 0 0 .98-.31 3.2 1.18.93-.26 1.93-.4 2.92-.4.99 0 2 .14 2.92.4 2.22-1.5 3.2-1.18 3.2-1.18.64 1.65.24 2.87.12 3.17.75.8 1.2 1.82 1.2 3.07 0 4.38-2.69 5.35-5.25 5.63.41.35.77 1.04.77 2.1v3.12c0 .31.21.67.8.56A10.99 10.99 0 0 0 23.5 12c0-6.35-5.15-11.5-11.5-11.5z"/>
            </svg>

            <span>View source on GitHub</span>
            <span class="arrow">→</span>

          </a>
        </p>

        <!-- Features -->
        <h2>Features</h2>
        <ul>
          <li>Interactive environment overview</li>
          <li>Automatic fixes for missing tools</li>
          <li>Check individual tools</li>
          <li>Full diagnostics reporting</li>
          <li>Cross-platform support (macOS, Linux, Windows)</li>
          <li>Coverage for runtimes, databases, and DevOps tooling</li>
        </ul>

        <!-- Installation -->
        <h2>Installation</h2>
        <pre>
git clone https://github.com/paszed/doctor.git
cd doctor
go build -o doctor ./cmd/doctor
        </pre>

        <!-- Usage -->
        <h2>Usage</h2>
        <pre>
# Interactive mode
./doctor

# Full diagnostics
./doctor diagnose

# Check a tool
./doctor check docker

# Fix issues
./doctor fix
./doctor fix docker

# Check port
./doctor port 3000
        </pre>

        <!-- Example -->
        <h2>Example</h2>
        <pre>
./doctor
./doctor diagnose
./doctor check docker
./doctor fix docker
        </pre>

        <!-- Supported -->
        <h2>Supported</h2>
        <ul>
          <li>Languages: Go, Node.js, Python, Java, Ruby</li>
          <li>Databases: PostgreSQL, MySQL, MongoDB, Redis</li>
          <li>DevOps: Docker, Kubernetes, Terraform, AWS CLI</li>
          <li>Other: GitHub CLI, Ansible, Maven</li>
        </ul>

      </div>
    </div>
  </body>
</html>
