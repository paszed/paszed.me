---
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>doctor</title>

    <style>
      body {
        margin: 0;
        background: #0a0a0a;
        color: #eaeaea;
        font-family: 'Inter', -apple-system, sans-serif;
      }

      .container {
        max-width: 720px;
        margin: 0 auto;
        padding: 120px 24px;
      }

      h1 {
        font-size: 42px;
        letter-spacing: -1px;
        margin-bottom: 10px;
      }

      .subtitle {
        color: #777;
        margin-bottom: 50px;
      }

      pre {
        background: #111;
        padding: 16px;
        border-radius: 6px;
        overflow-x: auto;
      }

      .back {
        color: #666;
        text-decoration: none;
        display: inline-block;
        margin-bottom: 40px;
      }

      .back:hover {
        color: #fff;
      }
    </style>
  </head>

  <body>
    <div class="container">

      <a href="/" class="back">← back</a>

      <h1>doctor</h1>
      <p class="subtitle">
        Diagnose developer environments and verify installed tooling.
      </p>

      <h2>Install</h2>
      <pre>brew install doctor</pre>

      <h2>Usage</h2>
      <pre>doctor check</pre>

    </div>
  </body>
</html>
