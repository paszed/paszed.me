---
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>doctor</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

  <style>
    html { scroll-behavior: smooth; }

    body {
      margin: 0;
      background: radial-gradient(circle at top, rgba(255,255,255,0.04), transparent 50%), #0a0a0a;
      color: #eaeaea;
      font-family: 'Inter', -apple-system, sans-serif;
    }

    .wrapper {
      max-width: 1000px;
      margin: 0 auto;
      padding: 0 20px;
    }

    .container {
      max-width: 680px;
      margin: 0 auto;
      padding: 120px 0;
      animation: fadeIn 0.6s ease;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    a {
      color: #aaa;
      text-decoration: none;
      transition: 0.2s;
    }

    a:hover {
      color: #fff;
      transform: translateX(3px);
    }

    .back {
      display: inline-block;
      margin-bottom: 40px;
      color: #666;
    }

    h1 {
      font-size: 48px;
      margin-bottom: 10px;
      letter-spacing: -1px;
    }

    .subtitle {
      color: #777;
      font-size: 18px;
      margin-bottom: 32px;
      line-height: 1.6;
    }

    .github {
      margin-bottom: 48px;
    }

    .github-link {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      color: #aaa;
    }

    .github-link:hover {
      color: #fff;
    }

    .icon {
      width: 18px;
      height: 18px;
      fill: currentColor;
    }

    h2 {
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 1.6px;
      color: #555;
      margin-top: 60px;
      margin-bottom: 16px;
    }

    ul {
      padding-left: 18px;
      color: #aaa;
      line-height: 1.6;
      font-size: 15px;
    }

    li {
      margin-bottom: 8px;
    }

    pre {
      background: #111;
      padding: 18px;
      border-radius: 6px;
      overflow-x: auto;
      font-size: 14px;
      line-height: 1.5;
    }

    .divider {
      height: 1px;
      background: #1a1a1a;
      margin: 48px 0;
    }

    @media (max-width: 600px) {
      .container { padding: 100px 0; }
      h1 { font-size: 36px; }
      .subtitle { font-size: 16px; }
    }
  </style>
</head>

<body>
  <div class="wrapper">
    <div class="container">

      <!-- Back -->
      <a href="/" class="back">← back</a>

      <!-- Title -->
      <h1>🩺 doctor</h1>
      <p class="subtitle">
        Developer environment diagnostics CLI.<br/>
        Automatically check, diagnose, and fix your development setup.
      </p>

      <!-- GitHub -->
      <p class="github">
        <a href="https://github.com/paszed/doctor" target="_blank" class="github-link">
          <svg class="icon" viewBox="0 0 24 24">
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.38 7.86 10.9.58.1.79-.25.79-.56v-2.17c-3.2.7-3.87-1.54-3.87-1.54-.52-1.32-1.27-1.67-1.27-1.67-1.04-.7.08-.69.08-.69 1.15.08 1.75 1.18 1.75 1.18 1.02 1.75 2.68 1.24 3.34.95.1-.74.4-1.24.73-1.52-2.56-.29-5.26-1.28-5.26-5.7 0-1.26.45-2.3 1.18-3.11-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11.1 11.1 0 0 1 2.9-.39c.98 0 1.97.13 2.9.39 2.2-1.5 3.17-1.18 3.17-1.18.63 1.59.24 2.76.12 3.05.73.81 1.18 1.85 1.18 3.11 0 4.43-2.7 5.4-5.27 5.68.41.35.78 1.04.78 2.1v3.12c0 .31.21.67.8.56A10.51 10.51 0 0 0 23.5 12c0-6.35-5.15-11.5-11.5-11.5z"/>
          </svg>
          <span>View source on GitHub →</span>
        </a>
      </p>

      <div class="divider"></div>

      <!-- Features -->
      <h2>⚡ Features</h2>
      <ul>
        <li>Interactive environment overview</li>
        <li>Automatic fixes for missing tools</li>
        <li>Check individual tools</li>
        <li>Full diagnostics reporting</li>
        <li>Cross-platform (macOS, Linux, Windows)</li>
      </ul>

      <!-- Installation -->
      <h2>📦 Installation</h2>
      <pre>
git clone https://github.com/paszed/doctor.git
cd doctor
go build -o doctor ./cmd/doctor
      </pre>

      <!-- Usage -->
      <h2>🚀 Usage</h2>
      <pre>
./doctor
./doctor diagnose
./doctor check docker
./doctor fix docker
      </pre>

      <!-- Example -->
      <h2>🧪 Example</h2>
      <pre>
./doctor check pip
./doctor fix pip
      </pre>

      <!-- Philosophy -->
      <h2>🧠 Why</h2>
      <p class="subtitle">
        Your environment should never block you from building.<br/>
        Doctor removes friction so you can focus on shipping.
      </p>

    </div>
  </div>
</body>
</html>
